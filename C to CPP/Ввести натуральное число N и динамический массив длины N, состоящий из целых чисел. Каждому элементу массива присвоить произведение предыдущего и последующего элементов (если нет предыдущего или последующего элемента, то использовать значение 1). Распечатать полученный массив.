#include <iostream>

int main()
{
    int N;
    std::cin >> N;
    int *arr = new int[N];
    for(int i = 0; i < N; i++) {
        std::cin >> arr[i];
    }
    int *verjnakanarr = new int[N];
    for(int i = 0; i < N; i++) {
        if(i == 0) {
            arr[i-1] = 1;
        } else if(i == N-1) {
            arr[i+1] = 1;
        }
        verjnakanarr[i] = arr[i-1] * arr[i + 1];
    }
    for(int i = 0; i < N; i++) {
        std::cout << verjnakanarr[i] << " ";
    }
    return 0;
}
