#include <iostream>
#include <climits>

int main()
{
    int N;
    std::cin >> N;
    int *arr = new int[N];
    for(int i = 0; i < N; i++) {
        std::cin >> arr[i];
    }
    int min1 = INT_MAX;
    int min2 = INT_MAX;
    int min3 = INT_MAX;
    
    for(int i = 0; i < N; i++) {
        int x = arr[i];
        if(x < min1) {
            min3 = min2;
            min2 = min1;
            min1 = x;
        } else if((x > min1) && (x < min2)) {
            min3 = min2;
            min2 = x;
        } else if((x > min2) && (x < min3)) {
            min3 = x;
        }
    }
    std::cout << min1 << " " << min2 << " " << min3;
    return 0;
}
