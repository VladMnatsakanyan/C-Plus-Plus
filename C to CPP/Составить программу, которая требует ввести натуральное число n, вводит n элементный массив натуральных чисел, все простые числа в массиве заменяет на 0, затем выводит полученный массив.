#include <iostream>

int parz(int x) {
    if(x <= 1) {
        return 0;
    } 
    for(int i = 2; i * i <= x; i++) {
        if(x % i == 0) {
            return 0;
        }
    }
    return 1;
}
int main()
{
    int n;
    std::cin >> n;
    int arr[n];
    for(int i = 0; i < n; i++) {
        std::cin >> arr[i];
    }
    for(int i = 0; i < n; i++) {
        if(parz(arr[i]) == 1) {
            arr[i] = 0;
        }
    }
    for(int i = 0; i < n; i++) {
        std::cout << arr[i] << ' ';
    }
    return 0;
}
