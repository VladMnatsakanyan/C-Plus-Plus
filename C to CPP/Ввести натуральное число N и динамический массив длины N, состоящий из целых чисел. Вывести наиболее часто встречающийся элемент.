#include <iostream>

int main()
{
    int N;
    std::cin >> N;
    int *arr = new int[N];
    for(int i = 0; i < N; i++) {
        std::cin >> arr[i];
    }
    int min = 0;
    int a;
    for(int i = 0; i < N; i++) {
        int count = 0;
        for(int j = 0; j < N; j++) {
            if(arr[i] == arr[j]) {
                count++;
            }
        }
        if(count > min) {
            min = count;
            a = arr[i];
        }
    }
    std::cout << a;
    delete[] arr;
    return 0;
}
