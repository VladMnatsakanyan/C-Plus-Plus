#include <iostream>
#include <iomanip>
#include <string>

class BankAccount {
private:
    int accountNumber;
    double balance;
    std::string ownerName;
    int pin;

    bool isPinCorrect(int enteredPin) const {
        return enteredPin == pin;
    }

    bool isWithdrawalAllowed(double amount) const {
        return amount > 0 && amount <= balance;
    }

public:
    BankAccount(int accNum, const std::string& name, double initialBalance, int initialPin)
        : accountNumber(accNum), ownerName(name), balance(initialBalance), pin(initialPin) {}

    BankAccount(const BankAccount& other) : accountNumber(other.accountNumber), balance(other.balance), ownerName(other.ownerName), pin(other.pin)
    {
        std::cout << "Account copied from " << ownerName << ". "<< std::endl;
    }

    ~BankAccount() {
        std::cout << "Account for " << ownerName << " is closed." << std::endl;
    }

};

int main() {
    BankAccount acc1(123456789, "John Doe", 1000.50, 1234);

    BankAccount acc2 = acc1;

    return 0;
}
