#include <iostream>
#include <iomanip>

class Point {
private:
    double x;
    double y;

public:
    Point(double x = 0, double y = 0) : x(x), y(y) {}

    Point(const Point& other) : x(other.x), y(other.y) {
        std::cout << "Point copied at (" << std::fixed << std::setprecision(2) << x << ", " << y << ")." << std::endl;
    }

    ~Point() {
        std::cout << "Point at (" << std::fixed << std::setprecision(2) << x << ", " << y << ") destroyed." << std::endl;
    }

    void move(double dx, double dy) {
        x += dx;
        y += dy;
    }

    void display() const {
        std::cout << "(" << std::fixed << std::setprecision(2) << x << ", " << y << ")";
    }
};

int main() {
    Point p1(3, 4);

    std::cout << "Point p1: ";
    p1.display();
    std::cout << std::endl;

    Point p2 = p1;

    p2.move(1, 2);

    std::cout << "Point p2: ";
    p2.display();
    std::cout << std::endl;

    return 0;
}
