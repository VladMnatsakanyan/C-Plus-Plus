#include <iostream>

void Swap(int &x, int &y) {
    int temp = x;
    x = y;
    y = temp;
}
int main()
{
    int n;
    int k;
    std::cin >> n >> k;
    int arr[n];
    int arr2[k];
    int arr3[n+k];
    for(int i = 0; i < n; i++) {
        std::cin >> arr[i];
    }
    for(int i = 0; i < k; i++) {
        std::cin >> arr2[i];
    }
    for(int i = 0; i < n; i++) {
        arr3[i] = arr[i];
    }
    for(int i = 0; i < k; i++) {
        arr3[n + i] = arr2[i];
    }
    int swapped;
    for(int i = 0; i < (n+k-1); i++) {
        swapped = 0;
        for(int j = 0; j < (n+k-i-1); j++) {
            if(arr3[j] > arr3[j + 1]) {
            Swap(arr3[j], arr3[j + 1]);
            swapped = 1;
            }
        }
        if(swapped == 0) {
            break;
        }
    }
    for(int i = 0; i < n+k; i++) {
        std::cout << arr3[i] << ' ';
    }
    return 0;
}
