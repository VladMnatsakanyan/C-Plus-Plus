#include <iostream>

void cycleValues(int &x, int &y, int &z) {
    int temp = z;
    z = y;
    y = x;
    x = temp;
}

int main()
{
    int x;
    int y;
    int z;
    std::cin >> x;
    std::cin >> y;
    std::cin >> z;
    cycleValues(x, y, z);
    std::cout << x << ' ' << y << ' ' << z;
    return 0;
}
