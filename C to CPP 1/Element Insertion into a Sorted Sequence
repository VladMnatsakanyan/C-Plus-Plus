#include <iostream>

int main()
{
    int n;
    std::cin >> n;
    double arr[n];
    for(int i = 0; i < n; i++) {
        std::cin >> arr[i];
    }
    double k;
    std::cin >> k;
    int swapped;
    for(int i = 0; i < n - 1; i++) {
        int swapped;
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                double temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                swapped = 1;
            }
        }
        if(swapped == 0) {
            break;
        }
    }
    int tex = 0;
    while(tex < n && arr[tex] < k) {
        tex++;
    }
    for(int i = 0; i < tex; i++) {
        std::cout << arr[i] << " ";
    }
    std::cout << k << " ";
    for(int i = tex; i < n; i++) {
        std::cout << arr[i] << " ";
    }
    return 0;
}
