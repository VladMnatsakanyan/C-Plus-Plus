#include <iostream>

int main()
{
    int n;
    std::cin >> n;
    int *arr = new int[n];
    for(int i = 0; i < n; i++) {
        std::cin >> arr[i];
    }
    int maxCount = 0;
    int tarr;
    for(int i = 0; i < n; i++) {
        int count = 0;
        for(int j = 0; j < n; j++) {
            if(arr[i] == arr[j]) {
                count++;
            }
            if(count > maxCount) {
                maxCount = count;
                tarr = arr[i];
            }
        }
    }
    std::cout << tarr << " " << maxCount;
    delete[] arr; 
    return 0;
}
