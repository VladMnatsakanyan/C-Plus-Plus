#include <iostream>
#include <iomanip>
#include <cmath>

class Point {
private:
    double x;
    double y;

public:
    Point(double x = 0, double y = 0) : x(x), y(y) {}

    ~Point() {
        std::cout << "Point at (" << std::fixed << std::setprecision(2) << x << ", " << y << ") destroyed." << std::endl;
    }

    void setX(double xVal) { 
        x = xVal; 
    }
    void setY(double yVal) {
        y = yVal; 
    }

    double getX() const {
        return x; 
    }
    double getY() const {
        return y; 
    }
    
    void move(double dx, double dy) {
        x += dx;
        y += dy;
    }

    double distanceToOrigin() const {
        return std::sqrt(x * x + y * y);
    }

    double distanceTo(const Point& other) const {
        return std::sqrt((x - other.x) * (x - other.x) + (y - other.y) * (y - other.y));
    }

    void display() const {
        std::cout << "(" << std::fixed << std::setprecision(2) << x << ", " << y << ")";
    }
};

int main() {
    Point p1(3, 4);
    Point p2(6, 8);

    std::cout << "Point p1: ";
    p1.display();
    std::cout << std::endl;

    std::cout << "Point p2: ";
    p2.display();
    std::cout << std::endl;

    p1.move(1, -2);
    std::cout << "Moved p1 to: ";
    p1.display();
    std::cout << std::endl;

    std::cout << "Distance of p1 from the origin: " << std::fixed << std::setprecision(2) << p1.distanceToOrigin() << std::endl;

    std::cout << "Distance between p1 and p2: " << std::fixed << std::setprecision(2) << p1.distanceTo(p2) << std::endl;

    return 0;
}
